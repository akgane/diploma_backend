# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get this from Atlas → Connect → Drivers
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
MONGODB_DB_NAME=food_tracker

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate a strong random key, e.g.: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Firebase Cloud Messaging ───────────────────────────────────────────────────
# Path to your Firebase service account JSON inside the container
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── GEMINI ───────────────────────────────────────────────────
GEMINI_API_KEY=token

# ── SPOONACULAR ───────────────────────────────────────────────────
SPOONACULAR_API_KEY=token